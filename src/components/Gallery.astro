---
interface GalleryImage {
	filename: string;
	alt?: string;
}

interface Props {
	images: GalleryImage[];
}

const { images } = Astro.props;
const filteredImages = images?.filter((img) => img.filename) || [];
---

{filteredImages.length > 0 && (
	<section class="gallery">
		<div class="gallery__grid">
			{filteredImages.map((img, index) => (
				<button
					class="gallery__item"
					data-index={index}
					data-gallery-open
					type="button"
					aria-label={`Ver imagen ${img.alt || index + 1}`}
				>
					<img
						src={`${img.filename}/m/400x400/filters:format(webp):quality(75)`}
						alt={img.alt || ''}
						width="400"
						height="400"
						loading="lazy"
						decoding="async"
					/>
				</button>
			))}
		</div>

		<dialog class="lightbox" data-lightbox>
			<div class="lightbox__backdrop" data-lightbox-close></div>
			<button class="lightbox__close" data-lightbox-close type="button" aria-label="Cerrar">&times;</button>
			<button class="lightbox__prev" data-lightbox-prev type="button" aria-label="Anterior">&#8249;</button>
			<button class="lightbox__next" data-lightbox-next type="button" aria-label="Siguiente">&#8250;</button>
			<div class="lightbox__content">
				<img class="lightbox__img" data-lightbox-img src="" alt="" />
			</div>
			<span class="lightbox__counter" data-lightbox-counter></span>
		</dialog>
	</section>
)}

<script define:vars={{ imageData: filteredImages.map(img => ({ src: `${img.filename}/m/1200x0/filters:format(webp):quality(85)`, alt: img.alt || '' })) }}>
	const dialog = document.querySelector('[data-lightbox]');
	const img = document.querySelector('[data-lightbox-img]');
	const counter = document.querySelector('[data-lightbox-counter]');
	const buttons = document.querySelectorAll('[data-gallery-open]');
	let current = 0;

	function show(index) {
		current = index;
		img.src = imageData[current].src;
		img.alt = imageData[current].alt;
		counter.textContent = `${current + 1} / ${imageData.length}`;
		dialog.showModal();
	}

	function navigate(dir) {
		current = (current + dir + imageData.length) % imageData.length;
		img.src = imageData[current].src;
		img.alt = imageData[current].alt;
		counter.textContent = `${current + 1} / ${imageData.length}`;
	}

	buttons.forEach(btn => {
		btn.addEventListener('click', () => show(Number(btn.dataset.index)));
	});

	document.querySelector('[data-lightbox-prev]')?.addEventListener('click', () => navigate(-1));
	document.querySelector('[data-lightbox-next]')?.addEventListener('click', () => navigate(1));
	document.querySelectorAll('[data-lightbox-close]').forEach(el => {
		el.addEventListener('click', () => dialog.close());
	});

	dialog?.addEventListener('keydown', (e) => {
		if (e.key === 'ArrowLeft') navigate(-1);
		if (e.key === 'ArrowRight') navigate(1);
	});
</script>

<style>
	/* ===== Grid ===== */
	.gallery__grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
		gap: var(--space-xs);
		margin-top: var(--space-m);
	}

	.gallery__item {
		border: none;
		padding: 0;
		background: none;
		cursor: pointer;
		overflow: hidden;
		border-radius: var(--radius-m);
		aspect-ratio: 1;
		transition: transform 0.2s;
	}

	.gallery__item:hover {
		transform: scale(1.03);
	}

	.gallery__item img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	/* ===== Lightbox ===== */
	.lightbox {
		border: none;
		background: none;
		padding: 0;
		max-width: 100vw;
		max-height: 100vh;
		width: 100vw;
		height: 100vh;
		overflow: hidden;
	}

	.lightbox::backdrop {
		background: rgba(0, 0, 0, 0.92);
	}

	.lightbox__backdrop {
		position: fixed;
		inset: 0;
		z-index: 0;
	}

	.lightbox__content {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		height: 100%;
		padding: var(--space-xl) var(--space-2xl);
	}

	.lightbox__img {
		max-width: 100%;
		max-height: 85vh;
		object-fit: contain;
		border-radius: var(--radius-s);
		user-select: none;
		position: relative;
		z-index: 1;
	}

	.lightbox__close {
		position: fixed;
		top: var(--space-s);
		right: var(--space-s);
		z-index: 10;
		background: none;
		border: none;
		color: white;
		font-size: 2.5rem;
		cursor: pointer;
		line-height: 1;
		padding: 0.25em;
		opacity: 0.8;
		transition: opacity 0.2s;
	}

	.lightbox__close:hover {
		opacity: 1;
	}

	.lightbox__prev,
	.lightbox__next {
		position: fixed;
		top: 50%;
		transform: translateY(-50%);
		z-index: 10;
		background: rgba(255, 255, 255, 0.12);
		border: none;
		color: white;
		font-size: 2.5rem;
		cursor: pointer;
		padding: 0.3em 0.5em;
		border-radius: var(--radius-s);
		line-height: 1;
		opacity: 0.7;
		transition: opacity 0.2s, background 0.2s;
	}

	.lightbox__prev:hover,
	.lightbox__next:hover {
		opacity: 1;
		background: rgba(255, 255, 255, 0.22);
	}

	.lightbox__prev {
		left: var(--space-s);
	}

	.lightbox__next {
		right: var(--space-s);
	}

	.lightbox__counter {
		position: fixed;
		bottom: var(--space-s);
		left: 50%;
		transform: translateX(-50%);
		z-index: 10;
		color: white;
		font-size: var(--fs-body);
		font-family: var(--font-body);
		opacity: 0.7;
	}

	/* ===== Responsive ===== */
	@media (max-width: 768px) {
		.gallery__grid {
			grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
		}

		.lightbox__content {
			padding: var(--space-m) var(--space-s);
		}

		.lightbox__prev,
		.lightbox__next {
			font-size: 2rem;
			padding: 0.2em 0.4em;
		}
	}
</style>
